@model GarageViewModel
@{
    ViewData["Title"] = "Mon Garage";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-section-title h2 mb-0">Mon <span class="hl">Garage</span></h1>
    <a class="btn btn-primary" asp-controller="Home" asp-action="Index">+ Ajouter une moto</a>
</div>

@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success">@ok</div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

@if (!Model.Items.Any())
{
    <div class="alert alert-info">
        Aucune moto pour l'instant. <a asp-controller="Home" asp-action="Index">Ajoutez-en une</a>.
    </div>
}
else
{
    @foreach (var item in Model.Items)
    {
        var m = item.Motorcycle;
        <div class="card moto-card shadow-sm mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div class="text-uppercase fw-bold">
                    @m.Make @m.Model <span class="text-muted fw-normal">· @m.Year</span>
                </div>
                <form asp-controller="Garage" asp-action="Remove" method="post"
                      onsubmit="return confirm('Supprimer cette moto ?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@m.Id"/>
                    <button class="btn btn-sm btn-outline-danger" type="submit">Supprimer</button>
                </form>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3 mb-3 mb-md-0">
                        @if (!string.IsNullOrEmpty(m.ImageUrl))
                        {
                            <img src="@m.ImageUrl" class="moto-photo mb-2" alt="@m.Make @m.Model"/>
                        }
                        else
                        {
                            <div class="photo-placeholder d-flex align-items-center justify-content-center small mb-2">
                                Pas de photo
                            </div>
                        }
                        <form asp-controller="Garage" asp-action="RefreshPhoto" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@m.Id"/>
                            <button class="btn btn-sm btn-outline-secondary w-100" type="submit">
                                @(string.IsNullOrEmpty(m.ImageUrl) ? "Chercher une photo" : "Rafraîchir la photo")
                            </button>
                        </form>
                    </div>
                    <div class="col-md-9">
                        <div class="row">
                            <div class="col-sm-6">
                                <h6>Caractéristiques</h6>
                                <ul class="list-unstyled small mb-3">
                                    <li><strong>Cylindrée :</strong> @(m.DisplacementCc is int cc ? $"{cc} cc" : "—")</li>
                                    <li><strong>Cylindres :</strong> @(m.Cylinders?.ToString() ?? "—")</li>
                                    <li><strong>Carburant :</strong> @(m.FuelType ?? "—")</li>
                                    <li><strong>Freinage :</strong> @(m.BrakeSystem ?? "—")</li>
                                    <li><strong>Catégorie :</strong> @(m.BodyClass ?? "—")</li>
                                    <li><strong>VIN :</strong> @(m.Vin ?? "—")</li>
                                </ul>
                            </div>
                            <div class="col-sm-6">
                                <h6>Kilométrage</h6>
                                <form asp-controller="Garage" asp-action="UpdateMileage" method="post" class="row g-2 align-items-center">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@m.Id"/>
                                    <div class="col-auto">
                                        <div class="input-group">
                                            <input type="number" min="0" name="mileageKm" value="@m.CurrentMileageKm"
                                                   class="form-control" style="max-width: 140px"/>
                                            <span class="input-group-text">km</span>
                                        </div>
                                    </div>
                                    <div class="col-auto">
                                        <button class="btn btn-outline-primary" type="submit">Mettre à jour</button>
                                    </div>
                                </form>
                                <p class="small text-muted mt-1">
                                    Dernière mise à jour : @m.MileageUpdatedUtc.ToLocalTime().ToString("g")
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <hr/>
                <h6>Entretien (à @m.CurrentMileageKm.ToString("N0") km)</h6>
                <partial name="_MaintenanceList" model="item"/>

                <div class="mt-3">
                    <button class="btn btn-sm btn-link p-0 text-decoration-none" type="button"
                            data-bs-toggle="collapse" data-bs-target="#hist-@m.Id">
                        Historique des entretiens (@item.History.Count) ▾
                    </button>
                    <div class="collapse mt-2" id="hist-@m.Id">
                        @if (!item.History.Any())
                        {
                            <p class="small text-muted mb-0">Aucune intervention enregistrée pour l'instant.</p>
                        }
                        else
                        {
                            <table class="table table-sm mb-0">
                                <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Entretien</th>
                                    <th>Km</th>
                                    <th class="text-end"></th>
                                </tr>
                                </thead>
                                <tbody>
                                @foreach (var h in item.History)
                                {
                                    <tr>
                                        <td>@h.DateUtc.ToLocalTime().ToString("dd/MM/yyyy")</td>
                                        <td>@h.TaskName</td>
                                        <td>@h.Km.ToString("N0") km</td>
                                        <td class="text-end">
                                            <form asp-controller="Garage" asp-action="DeleteRecord" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="recordId" value="@h.RecordId"/>
                                                <button class="btn btn-sm btn-outline-danger" type="submit" title="Supprimer cette entrée">✕</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
}
