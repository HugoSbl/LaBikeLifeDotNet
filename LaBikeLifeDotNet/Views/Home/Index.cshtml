@model MotorcycleSearchViewModel?
@{
    ViewData["Title"] = "Accueil";
}

@if (User.Identity?.IsAuthenticated == true && Model is not null)
{
    @if (TempData["Error"] is string err)
    {
        <div class="alert alert-danger">@err</div>
    }

    <div class="mb-section">
        <h2 class="mb-section-title">Recherche ta <span class="hl">moto</span></h2>
        <p class="mb-section-sub">Marque, année, modèle — et c'est parti.</p>
        <div class="mb-rule"></div>
    </div>

    <div class="d-flex justify-content-end mb-2">
        <a class="btn btn-outline-primary btn-sm" asp-controller="Garage" asp-action="Index">Mon Garage ›</a>
    </div>

    <div class="card mb-card mb-card-accent shadow-sm">
        <div class="card-body">
            <partial name="_MotorcycleSearch" model="Model"/>
        </div>
    </div>

    <p class="text-muted mt-2 small">
        Données moto via l'API gratuite NHTSA vPIC ; photo via Wikipedia. Renseignez le VIN pour les
        caractéristiques détaillées. L'entretien est calculé selon votre kilométrage.
    </p>
}
else
{
    <div class="mb-hero mb-5">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h1 class="display-4 mb-3">Ta moto. <span class="accent">Au carré.</span></h1>
                <p class="lead mb-4">
                    Recherche ta bécane, consulte ses caractéristiques et garde un œil sur tous les
                    entretiens à faire selon ton kilométrage.
                </p>
                <a class="btn btn-primary btn-lg me-2" asp-area="Identity" asp-page="/Account/Login">Se connecter ›</a>
                <a class="btn btn-outline-light btn-lg" asp-area="Identity" asp-page="/Account/Register">Créer un compte</a>
            </div>
        </div>
    </div>

    <div class="mb-section">
        <h2 class="mb-section-title">Tout pour ta <span class="hl">bécane</span></h2>
        <p class="mb-section-sub">Simple, gratuit, sans prise de tête.</p>
        <div class="mb-rule"></div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card mb-card mb-card-accent h-100 shadow-sm">
                <div class="card-body text-center">
                    <div class="display-6 mb-2">🔍</div>
                    <h5 class="text-uppercase">Recherche</h5>
                    <p class="small text-muted mb-0">Trouve ta moto par marque, année et modèle.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card mb-card mb-card-accent h-100 shadow-sm">
                <div class="card-body text-center">
                    <div class="display-6 mb-2">📋</div>
                    <h5 class="text-uppercase">Caractéristiques</h5>
                    <p class="small text-muted mb-0">Cylindrée, freinage, carburant… via le VIN.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card mb-card mb-card-accent h-100 shadow-sm">
                <div class="card-body text-center">
                    <div class="display-6 mb-2">🛠️</div>
                    <h5 class="text-uppercase">Entretien</h5>
                    <p class="small text-muted mb-0">Les entretiens à faire selon ton kilométrage.</p>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="~/js/garage.js" asp-append-version="true"></script>
}
